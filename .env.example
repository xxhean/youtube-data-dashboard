PORT=3000
API_KEY=your-api-key-here
YOUTUBE_API_KEY=your-youtube-api-key
REFRESH_CRON=0 2 * * *
REFRESH_BATCH_SIZE=50

# Google OAuth (一键登录)
# 在 Google Cloud Console 创建 OAuth 2.0 客户端 ID 后填入
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
SESSION_SECRET=your-random-session-secret-here

# Cloudflare R2 对象存储 (存储用户上传的头像或生成的缩略图)
# 登录 Cloudflare -> R2 -> 创建存储桶 (Bucket) -> Settings -> S3 API 参数
R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=youtube-dashboard-media
R2_PUBLIC_URL_PREFIX=https://pub-xxxxxx.r2.dev

# Cloudflare Turnstile (人机验证)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend (邮件发送)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
